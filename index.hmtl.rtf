  <!-- Dark Mode Toggle Script -->\par
  <script>\par
    const toggle = document.getElementById('theme-toggle');\par
    const sun = document.getElementById('sun');\par
    const moon = document.getElementById('moon');\par
    \par
    // Check saved preference or system\par
    if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) \{\par
      document.documentElement.classList.add('dark');\par
      sun.classList.remove('hidden');\par
      moon.classList.add('hidden');\par
    \} else \{\par
      document.documentElement.classList.remove('dark');\par
      sun.classList.add('hidden');\par
      moon.classList.remove('hidden');\par
    \}\par
\par
    toggle.addEventListener('click', () => \{\par
      document.documentElement.classList.toggle('dark');\par
      if (document.documentElement.classList.contains('dark')) \{\par
        localStorage.theme = 'dark';\par
        sun.classList.remove('hidden');\par
        moon.classList.add('hidden');\par
      \} else \{\par
        localStorage.theme = 'light';\par
        sun.classList.add('hidden');\par
        moon.classList.remove('hidden');\par
      \}\par
    \});\par
